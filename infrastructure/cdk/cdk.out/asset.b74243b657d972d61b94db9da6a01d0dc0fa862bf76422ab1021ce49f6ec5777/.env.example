# AI FocusFlow - Backend Environment Variables

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# DynamoDB Tables (auto-set by SAM in deployed env)
TASKS_TABLE=FocusFlow-Tasks-dev
PLANS_TABLE=FocusFlow-Plans-dev
INSIGHTS_TABLE=FocusFlow-Insights-dev
NOTIFICATIONS_TABLE=FocusFlow-Notifications-dev

# Amazon Bedrock
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Cognito (from CloudFormation outputs)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
